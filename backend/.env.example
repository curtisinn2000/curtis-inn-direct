NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/curtis_inn
JWT_SECRET=replace-with-a-strong-local-secret
JWT_EXPIRES_IN=12h
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
PUBLIC_SITE_URL=http://localhost:8080
TAX_RATE=0.13
DEPOSIT_RULE=one_night

# Stripe server-only secrets. Use test mode first.
STRIPE_ENV=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Gmail / Google Workspace SMTP
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
MAIL_FROM=reservations@curtisinnsuites.com

# Optional first admin seed values for npm run seed:admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Front Desk
